---
const model = {
  name: 'Emerald',
  tagline: 'El espacio perfecto para tu familia en Culiacán, Sinaloa.',
  image: '/images/modelo-emerald.jpg',
  imageAlt: 'Fachada Modelo Emerald – Vistas Altaria',
  price: '1,229,000',
  specs: [
    { icon: 'bed',     label: '2 Recámaras' },
    { icon: 'bath',    label: '1 Baño' },
    { icon: 'car',     label: 'Cochera' },
    { icon: 'area',    label: '50.74 m² construcción' },
    { icon: 'land',    label: '96 m² terreno' },
  ],
  features: [
    { icon: 'kitchen', label: 'Cocina integral' },
    { icon: 'blinds',  label: 'Persianas' },
    { icon: 'water',   label: 'Tinaco' },
    { icon: 'shower',  label: 'Baño con cancel' },
    { icon: 'mirror',  label: 'Lavabo con espejo luz LED' },
    { icon: 'shield',  label: 'Protectores' },
    { icon: 'door',    label: 'Puerta de seguridad' },
    { icon: 'grass',   label: 'Pasto sintético' },
  ],
};

const specIcons: Record<string, string> = {
  bed:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg>`,
  bath: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16M4 12a2 2 0 01-2-2V7a2 2 0 012-2h3m13 7a2 2 0 002-2V7a2 2 0 00-2-2h-3M4 12v5a2 2 0 002 2h12a2 2 0 002-2v-5"/></svg>`,
  car:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 6H7L4 10v4h16v-4l-3-4zM4 14h16"/></svg>`,
  area: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>`,
  land: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
};

const featIcons: Record<string, string> = {
  kitchen: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  blinds:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>`,
  water:   `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3C12 3 5 10 5 15a7 7 0 0014 0c0-5-7-12-7-12z"/></svg>`,
  shower:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16M4 12a2 2 0 01-2-2V7a2 2 0 012-2h3m13 7a2 2 0 002-2V7a2 2 0 00-2-2h-3M4 12v5a2 2 0 002 2h12a2 2 0 002-2v-5"/></svg>`,
  mirror:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  shield:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  door:    `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12V5a2 2 0 012-2h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2v-4m0-3h9m0 0l-3-3m3 3l-3 3"/></svg>`,
  grass:   `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
};
---

<section id="modelos" class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-brand-red font-semibold text-sm tracking-widest uppercase mb-3">
        Modelo disponible
      </span>
      <h2 class="text-4xl lg:text-5xl font-black text-brand-charcoal leading-tight">
        Modelo <span class="text-brand-red">Emerald</span>
      </h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        Una casa diseñada para que tu familia viva con comodidad y seguridad desde el primer día.
      </p>
    </div>

    <!-- Card -->
    <div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-lg ring-1 ring-gray-200 overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2">

        <!-- Fachada (lightbox) -->
        <div class="relative">
          <button
            type="button"
            data-lightbox
            data-src={model.image}
            data-alt={model.imageAlt}
            class="group/img block w-full aspect-[4/3] lg:h-full lg:aspect-auto overflow-hidden cursor-zoom-in"
            aria-label={`Ampliar fachada del Modelo ${model.name}`}
          >
            <img
              src={model.image}
              alt={model.imageAlt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover/img:scale-105"
            />
            <span class="absolute top-3 right-3 w-9 h-9 rounded-full bg-black/45 text-white flex items-center justify-center opacity-0 group-hover/img:opacity-100 transition-opacity">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 8v6M8 11h6M19 11a8 8 0 11-16 0 8 8 0 0116 0z"/></svg>
            </span>
          </button>
          <div class="absolute top-4 left-4 pointer-events-none">
            <span class="inline-flex items-center gap-1.5 bg-brand-red text-white font-bold text-xs px-3 py-1.5 rounded-full shadow tracking-wide uppercase">
              Modelo Emerald
            </span>
          </div>
        </div>

        <!-- Contenido -->
        <div class="p-6 sm:p-8 lg:p-10 flex flex-col">
          <h3 class="text-3xl font-black text-brand-charcoal">Modelo Emerald</h3>
          <p class="text-gray-500 text-sm mt-1 mb-6">{model.tagline}</p>

          <!-- Specs -->
          <div class="grid grid-cols-2 gap-3 mb-6">
            {model.specs.map((spec) => (
              <div class="flex items-center gap-2 text-sm text-brand-charcoal">
                <span class="text-brand-red">
                  <Fragment set:html={specIcons[spec.icon]} />
                </span>
                <span class="font-medium">{spec.label}</span>
              </div>
            ))}
          </div>

          <!-- Características incluidas -->
          <div class="rounded-2xl bg-gray-50 ring-1 ring-gray-200 p-5 mb-6">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">
              Incluido en tu casa
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-3">
              {model.features.map((feat) => (
                <div class="flex items-center gap-2.5 text-sm text-brand-charcoal">
                  <span class="text-brand-red flex-shrink-0">
                    <Fragment set:html={featIcons[feat.icon]} />
                  </span>
                  <span class="font-medium">{feat.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Precio + CTA -->
          <div class="mt-auto flex items-end justify-between gap-4 flex-wrap pt-2">
            <div>
              <p class="text-[11px] text-gray-400 leading-none mb-1 uppercase tracking-wide">Precio de lista</p>
              <p class="font-black text-brand-red text-3xl leading-none">${model.price}</p>
              <p class="text-[11px] text-gray-400 mt-1">pesos mexicanos</p>
            </div>
            <a
              href="#contacto"
              class="inline-flex items-center justify-center px-7 py-3 rounded-full font-bold text-sm bg-brand-red text-white hover:bg-red-600 shadow-lg shadow-red-500/20 transition-all"
            >
              Me interesa
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Nota -->
    <p class="text-center text-xs text-gray-400 mt-8 max-w-2xl mx-auto">
      Precio sujeto a cambio sin previo aviso. Consulta a un asesor para conocer las
      promociones y formas de pago disponibles este mes.
    </p>

  </div>
</section>
