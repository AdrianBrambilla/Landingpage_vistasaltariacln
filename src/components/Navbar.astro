---
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="#inicio" class="group font-black text-xl tracking-tight whitespace-nowrap">
        <span class="text-brand-red">VISTAS</span> <span class="text-brand-charcoal">ALTARIA</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-5 lg:gap-7 text-sm font-medium text-brand-charcoal">
        <li><a href="#modelos" class="hover:text-brand-red transition-colors">Modelos</a></li>
        <li><a href="#equipamiento" class="hover:text-brand-red transition-colors">Equipamiento</a></li>
        <li><a href="#amenidades" class="hover:text-brand-red transition-colors">Amenidades</a></li>
        <li><a href="#ubicacion" class="hover:text-brand-red transition-colors">Ubicación</a></li>
      </ul>

      <!-- CTA -->
      <a
        href="#contacto"
        class="hidden md:inline-flex items-center whitespace-nowrap px-5 py-2.5 bg-brand-red text-white text-sm font-semibold rounded-full hover:bg-red-600 transition-colors"
      >
        Agendar Visita
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-brand-charcoal hover:bg-gray-100"
        aria-label="Abrir menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden py-4 border-t border-gray-100">
      <ul class="flex flex-col gap-4 text-sm font-medium text-brand-charcoal">
        <li><a href="#modelos" class="block hover:text-brand-red transition-colors">Modelos</a></li>
        <li><a href="#equipamiento" class="block hover:text-brand-red transition-colors">Equipamiento</a></li>
        <li><a href="#amenidades" class="block hover:text-brand-red transition-colors">Amenidades</a></li>
        <li><a href="#ubicacion" class="block hover:text-brand-red transition-colors">Ubicación</a></li>
        <li>
          <a
            href="#contacto"
            class="inline-flex items-center px-5 py-2.5 bg-brand-red text-white text-sm font-semibold rounded-full hover:bg-red-600 transition-colors"
          >
            Agendar Visita
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((link) =>
    link.addEventListener('click', () => menu.classList.add('hidden'))
  );
</script>
