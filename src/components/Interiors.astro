---
const interiors = [
  {
    image: '/images/int-planta-baja.jpg',
    alt: 'Planta baja con cocina integrada – Portal de Bugambilia',
    title: 'Planta Baja Abierta',
    description: 'Sala, comedor y cocina integrada en un espacio amplio y luminoso.',
    span: true,
  },
  {
    image: '/images/int-sala.jpg',
    alt: 'Sala de estar – Portal de Bugambilia',
    title: 'Sala de Estar',
    description: 'Acceso directo y gran entrada de luz natural.',
    span: false,
  },
  {
    image: '/images/int-recamara.jpg',
    alt: 'Recámara con protecciones en ventana',
    title: 'Recámaras',
    description: 'Amplias, con protecciones en ventanas y vista despejada.',
    span: false,
  },
  {
    image: '/images/int-bano.jpg',
    alt: 'Baño privado con regadera tipo lluvia y cancel de vidrio',
    title: 'Baño Privado',
    description: 'Regadera tipo lluvia y cancel de vidrio templado.',
    span: false,
  },
  {
    image: '/images/int-escaleras.jpg',
    alt: 'Escaleras interiores',
    title: 'Escaleras',
    description: 'Conexión elegante entre plantas con barandal metálico.',
    span: false,
  },
  {
    image: '/images/int-mueble-tv.jpg',
    alt: 'Mueble de TV integrado en planta baja',
    title: 'Mueble de TV Integrado',
    description: 'Closet y centro de entretenimiento de fábrica incluidos.',
    span: false,
  },
];
---

<section id="interiores" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-brand-red font-semibold text-sm tracking-widest uppercase mb-3">
        Conoce por dentro
      </span>
      <h2 class="text-4xl lg:text-5xl font-black text-brand-charcoal leading-tight">
        Interiores <span class="text-brand-red">Reales</span>
      </h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        Fotografías reales de los espacios interiores. Acabados de primera, listos para habitar
        desde el primer día.
      </p>
    </div>

    <!-- Gallery -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {interiors.map((item) => (
        <div class={`group relative rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 ${item.span ? 'sm:col-span-2 lg:row-span-1' : ''}`}>
          <div class={item.span ? 'aspect-[16/10] lg:aspect-auto lg:h-full' : 'aspect-[4/3]'}>
            <img
              src={item.image}
              alt={item.alt}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent">
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="text-white font-bold text-lg">{item.title}</h3>
              <p class="text-white/80 text-sm mt-0.5">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
