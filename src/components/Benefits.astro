---
const benefits = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Acceso Controlado',
    subtitle: '24 horas al día',
    description: 'Caseta de seguridad con vigilancia permanente y acceso restringido para residentes y visitantes.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'Comunidad Segura',
    subtitle: 'Vecinos organizados',
    description: 'Red de vecinos comprometidos que se apoyan mutuamente, generando un ambiente de confianza y tranquilidad.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    title: 'Cocina Equipada',
    subtitle: 'Lista para usar',
    description: 'Cocina integral con gabinetes, cubierta y tarja incluidos. Solo mudate y empieza a vivir.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
    title: 'Pisos Premium',
    subtitle: 'Acabados de primera',
    description: 'Piso cerámico de alta calidad en toda la casa. Sin obra, sin gastos extras, listo desde el primer día.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Áreas Recreativas',
    subtitle: 'Para toda la familia',
    description: 'Cancha de fútbol, juegos infantiles y jardines paisajísticos donde los niños crecen felices y seguros.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
    title: 'Puerta de Seguridad',
    subtitle: 'Acero reforzado',
    description: 'Puerta principal con cerrojo de alta resistencia y protecciones en ventanas para la tranquilidad de tu hogar.',
  },
];
---

<section id="beneficios" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-brand-red font-semibold text-sm tracking-widest uppercase mb-3">
        ¿Por qué elegirnos?
      </span>
      <h2 class="text-4xl lg:text-5xl font-black text-brand-charcoal leading-tight">
        Beneficios <span class="text-brand-red">Exclusivos</span>
      </h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        Todo lo que necesitas para vivir con comodidad, seguridad y estilo desde el primer día.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {benefits.map((b) => (
        <div class="group p-6 rounded-2xl border border-gray-100 hover:border-brand-red/20 hover:shadow-xl hover:shadow-brand-red/5 transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-brand-red/10 text-brand-red flex items-center justify-center mb-5 group-hover:bg-brand-red group-hover:text-white transition-all duration-300">
            <Fragment set:html={b.icon} />
          </div>
          <h3 class="font-bold text-brand-charcoal text-lg">{b.title}</h3>
          <p class="text-brand-red text-sm font-medium mb-2">{b.subtitle}</p>
          <p class="text-gray-500 text-sm leading-relaxed">{b.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
