---
const items = [
  {
    image: '/images/equip-pasto.jpg',
    alt: 'Pasto sintético en cochera y patio',
    title: 'Pasto Sintético',
    description: 'Cochera y patio con pasto sintético instalado, listos para disfrutar sin mantenimiento.',
  },
  {
    image: '/images/equip-tinaco.jpg',
    alt: 'Tinaco de almacenamiento de agua',
    title: 'Tinaco',
    description: 'Tinaco de almacenamiento instalado para asegurar el suministro de agua en tu hogar.',
  },
  {
    image: '/images/equip-puerta.jpg',
    alt: 'Puerta de seguridad de acero reforzado',
    title: 'Puerta de Seguridad',
    description: 'Puerta principal de acero con cerrojo de alta resistencia. Robusta, elegante y lista desde la entrega.',
  },
  {
    image: '/images/equip-protectores.jpg',
    alt: 'Protectores reforzados de herrería en ventanas',
    title: 'Protectores Reforzados',
    description: 'Herrería de seguridad reforzada en ventanas y puertas corredizas, con diseño moderno.',
  },
  {
    image: '/images/equip-sanitario.jpg',
    alt: 'Sanitario ecológico de bajo consumo',
    title: 'Sanitario Ecológico',
    description: 'Sanitario ecológico de bajo consumo de agua, instalado en todos los baños.',
  },
  {
    image: '/images/equip-lavabo.jpg',
    alt: 'Lavabo con espejo de luz LED',
    title: 'Lavabo con Espejo LED',
    description: 'Lavabo con cubierta y espejo con luz LED integrada para un acabado moderno.',
  },
];
---

<section id="equipamiento" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-brand-red font-semibold text-sm tracking-widest uppercase mb-3">
        Sin sorpresas
      </span>
      <h2 class="text-4xl lg:text-5xl font-black text-brand-charcoal leading-tight">
        Equipamiento <span class="text-brand-red">Incluido</span>
      </h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        Todas las casas se entregan con este equipamiento base incluido en el precio. Toca cualquier
        foto para verla en grande.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {items.map((item) => (
        <div class="group flex flex-col rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300">
          <button
            type="button"
            data-lightbox
            data-src={item.image}
            data-alt={item.alt}
            class="relative overflow-hidden aspect-[4/3] cursor-zoom-in"
            aria-label={`Ampliar imagen: ${item.title}`}
          >
            <img
              src={item.image}
              alt={item.alt}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <!-- Zoom hint -->
            <span class="absolute top-3 right-3 w-9 h-9 rounded-full bg-black/45 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 8v6M8 11h6M19 11a8 8 0 11-16 0 8 8 0 0116 0z"/></svg>
            </span>
          </button>
          <div class="p-6 bg-white flex flex-col flex-1">
            <div class="w-10 h-1 bg-brand-red rounded-full mb-4"></div>
            <h3 class="text-xl font-bold text-brand-charcoal mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
