---
const nearbyPlaces = [
  { category: 'Vialidades', items: ['Av. Estación de Albacete', 'Blvd. Emiliano Zapata', 'Periférico de Culiacán'] },
  { category: 'Educación', items: ['Escuelas primarias (5 min)', 'Secundarias y preparatorias (8 min)', 'Universidad (15 min)'] },
  { category: 'Servicios', items: ['Supermercado (7 min)', 'Hospital (10 min)', 'Plaza comercial (12 min)'] },
  { category: 'Recreación', items: ['Parque urbano (5 min)', 'Restaurantes y cafés (6 min)', 'Centros deportivos (8 min)'] },
];
---

<section id="ubicacion" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block text-brand-red font-semibold text-sm tracking-widest uppercase mb-3">
        Conectado con todo
      </span>
      <h2 class="text-4xl lg:text-5xl font-black text-brand-charcoal leading-tight">
        Ubicación <span class="text-brand-red">Estratégica</span>
      </h2>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        En Culiacán, Sinaloa, con acceso directo a las principales vialidades y cerca de todos los servicios que tu familia necesita.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Map placeholder -->
      <div class="rounded-2xl overflow-hidden shadow-xl aspect-[4/3] bg-gray-100 relative">
        <iframe
          src="https://maps.google.com/maps?q=24.7571474,-107.363675&z=17&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="absolute inset-0 w-full h-full"
          title="Mapa de ubicación Vistas Altaria, Culiacán Sinaloa"
        ></iframe>
        <!-- Badge overlay -->
        <div class="absolute top-4 left-4 bg-white rounded-full px-4 py-2 shadow-lg flex items-center gap-2 pointer-events-none">
          <svg class="w-4 h-4 text-brand-red" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-brand-red font-semibold text-sm">Culiacán, Sinaloa</span>
        </div>
      </div>

      <!-- Info -->
      <div class="space-y-6">
        {nearbyPlaces.map((group) => (
          <div>
            <h3 class="font-bold text-brand-charcoal text-base mb-3 flex items-center gap-2">
              <span class="w-6 h-0.5 bg-brand-red inline-block rounded-full"></span>
              {group.category}
            </h3>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li class="flex items-center gap-3 text-gray-600 text-sm">
                  <svg class="w-4 h-4 text-brand-red flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}

        <a
          href="#contacto"
          class="inline-flex items-center gap-2 mt-4 px-6 py-3 bg-brand-red text-white font-semibold rounded-full hover:bg-red-600 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          ¿Cómo llegar?
        </a>
      </div>
    </div>
  </div>
</section>
